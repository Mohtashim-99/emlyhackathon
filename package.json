{
  "name": "remis",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:feast": "docker compose -f ./docker/feast/docker-compose-dev.yml up -d feast",
    "dev:mysql": "docker compose -f ./docker/feast/docker-compose-dev.yml up -d mysql",
    "dev:studio": "docker compose -f ./docker/feast/docker-compose-dev.yml up -d studio",
    "dev:migration": "docker compose -f ./docker/feast/docker-compose-dev.yml run --rm migration",
    "stop:feast": "docker compose -f ./docker/feast/docker-compose-dev.yml down feast mysql studio migration",
    "logs:feast": "docker logs $(docker ps --filter 'name=feast_backend' --format '{{.ID}}') -f",
    "logs:mysql": "docker logs $(docker ps --filter 'name=feast_mysql' --format '{{.ID}}') -f",
    "logs:studio": "docker logs $(docker ps --filter 'name=feast_studio' --format '{{.ID}}') -f",
    "logs:migration": "docker logs $(docker ps --filter 'name=feast_migration' --format '{{.ID}}') -f",
    "list:containers": "docker ps --format '{{.ID}} {{.Names}}'",
    "kill:docker": "docker kill $(docker ps -q)"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
